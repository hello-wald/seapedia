# $DOMAIN is injected from the .env file via docker-compose.prod.yml.

{$DOMAIN} {
	# /api/* -> NestJS API. Use `handle` (not `handle_path`) so the /api prefix
	# is preserved, matching the API's global prefix (setGlobalPrefix("api")).
	# Swagger lives at https://$DOMAIN/api/docs.
	handle /api/* {
		reverse_proxy api:3000
	}

	# Everything else -> the React Router web app.
	handle {
		reverse_proxy web:3000
	}
}
