# Production environment for docker-compose.prod.yml.
# Copy to `.env` on the VPS and fill in real values. `.env` is git-ignored.
#   cp .env.prod.example .env

# Public domain (DNS A record must already point at this VPS).
# Caddy provisions an HTTPS cert for it automatically.
DOMAIN=seapedia.example.com

# Postgres password (used by the postgres container AND in the API's DATABASE_URL).
POSTGRES_PASSWORD=change-me-strong-password

# --- API auth ---
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=7d

# Admin account created by the seed (run once: see README/verification).
ADMIN_EMAIL=admin@seapedia.local
ADMIN_PASSWORD=change-me-strong-password

SESSION_SECRET=change-me-long-random-string

# --- Cloudinary (image uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
