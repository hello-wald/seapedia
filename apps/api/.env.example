# PostgreSQL connection (matches docker-compose.yml at the repo root)
DATABASE_URL="postgresql://seapedia:seapedia@localhost:5432/seapedia?schema=public"

# API server
PORT=3000

# Allowed CORS origin for the web app
WEB_ORIGIN="http://localhost:5173"

# Auth
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# Admin seed account (created by `prisma db seed`)
ADMIN_EMAIL="admin@seapedia.local"
ADMIN_PASSWORD="change-me"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
